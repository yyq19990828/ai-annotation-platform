{
  "name": "ai-annotation-platform",
  "private": true,
  "scripts": {
    "prepare": "bash scripts/install-git-hooks.sh",
    "dev:web": "pnpm --filter @anno/web dev",
    "build:web": "pnpm --filter @anno/web build",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "lint": "pnpm --filter @anno/web lint",
    "typecheck": "pnpm --filter @anno/web typecheck",
    "test": "pnpm --filter @anno/web test",
    "test:e2e": "pnpm --filter @anno/web test:e2e",
    "codegen": "pnpm --filter @anno/web codegen",
    "openapi:export": "cd apps/api && uv run python ../../scripts/export_openapi.py",
    "openapi:check": "cd apps/api && uv run python ../../scripts/export_openapi.py --check",
    "docs:dev": "pnpm --filter @anno/docs-site dev",
    "docs:build": "pnpm --filter @anno/docs-site build",
    "docs:preview": "pnpm --filter @anno/docs-site preview",
    "docs:hotkeys": "pnpm --filter @anno/docs-site hotkeys"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316"
}
