# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/annotation

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=annotations

# Auth
SECRET_KEY=change-this-to-a-random-string-in-production

# Open registration (v0.7.7) — set to true to allow self-signup with viewer role
ALLOW_OPEN_REGISTRATION=false

# Frontend
VITE_API_URL=http://localhost:8000

# Sentry (v0.6.6) — leave empty to disable
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_DSN=

# CORS — JSON 列表或逗号分隔；production 必填，dev/staging 留空走默认 localhost 三件套
# CORS_ALLOW_ORIGINS=["https://app.example.com","https://admin.example.com"]
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
# 仅 dev/staging 生效，production 自动忽略以防误放本机正则上线
# CORS_ALLOW_ORIGIN_REGEX=http://localhost:\d+

# 部署环境：development | staging | production
ENVIRONMENT=development
