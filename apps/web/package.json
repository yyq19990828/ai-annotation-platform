{
  "name": "@anno/web",
  "private": true,
  "version": "0.8.8",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/codegen-if-changed.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "codegen": "openapi-ts",
    "codegen:watch": "openapi-ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "screenshots": "playwright test --config=playwright.screenshots.config.ts",
    "size": "node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@sentry/react": "^8.45.0",
    "@tanstack/react-query": "^5.60.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/rbush": "^4.0.0",
    "blurhash": "^2.0.5",
    "clsx": "^2.1.1",
    "html2canvas-pro": "^2.0.2",
    "idb-keyval": "^6.2.2",
    "konva": "^10.2.5",
    "lucide-react": "^1.14.0",
    "polygon-clipping": "^0.15.7",
    "rbush": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.14",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.1",
    "use-image": "^1.1.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@hey-api/openapi-ts": "^0.55.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.13.0",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  }
}
